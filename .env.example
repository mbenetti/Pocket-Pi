# Pocket-Pi Environment Configuration Example
# Copy this file to '.env' and fill in your private API keys.
# Do NOT commit your actual '.env' file to version control.

# ==============================================================================
# LLM Providers API Keys
# ==============================================================================

# Anthropic API Key (required if using claude models directly)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (required if using GPT models directly)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API Key (required if using OpenRouter integration)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ==============================================================================
# Web Searching & Tools API Keys
# ==============================================================================

# Tavily Search API Key (Optional)
# Used for high-fidelity web search / web crawling tools.
# If left blank, Pocket-Pi gracefully falls back to free Keyless DuckDuckGo Search.
# Get your key at: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here
